# Eyewear Studio — Storage Configuration
# 
# Leave these unset to use local placements.json (file-based storage).
# Set DATABASE_URL to use PostgreSQL (survives deploys on Render, Railway, Railway, etc.)

# PostgreSQL connection string (auto-creates the placements table)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to true if your PostgreSQL host requires SSL (e.g. Render, Railway cloud)
# DATABASE_SSL=true

# Port for the Express server (defaults to 3000)
# PORT=3000