# Eyewear Studio — Storage Configuration
# 
# LOCAL: Leave these unset to use local placements.json (file-based storage).
# DEPLOYED: Set both DATABASE_URL and DATABASE_SSL to use PostgreSQL.

# PostgreSQL connection string — auto-creates the "placements" table on first save.
# Get a free permanent PostgreSQL from Neon (neon.tech) or Supabase (supabase.com).
# DATABASE_URL=postgresql://user:password@ep-xyz.us-east-2.aws.neon.tech/dbname

# Required for Neon, Supabase, and most cloud PostgreSQL hosts
# DATABASE_SSL=true

# Port for the Express server (Render sets this automatically, but add for local testing)
# PORT=3000
